<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_sol_arabic" model="ir.ui.view">
        <field name="name">res.company.form.sol.arabic</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="arabic_name" placeholder="الاسم بالعربية"/>
                <field name="arabic_address" placeholder="العنوان بالعربية"/>
            </xpath>
        </field>
    </record>
</odoo>

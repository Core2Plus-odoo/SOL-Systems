<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_sol_arabic" model="ir.ui.view">
        <field name="name">res.partner.form.sol.arabic</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <separator string="Arabic Details / بيانات عربية"/>
                <field name="arabic_name" string="Arabic Name / الاسم بالعربية" placeholder="الاسم بالعربية"/>
                <field name="arabic_address" string="Arabic Address / العنوان بالعربية" placeholder="العنوان بالعربية"/>
            </xpath>
        </field>
    </record>
</odoo>
